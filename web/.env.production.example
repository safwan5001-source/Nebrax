#  متغيّرات بيئة الإنتاج للواجهة (Next.js) — تُضبط في Vercel
#  Project → Settings → Environment Variables (وليس من هذا الملف)
# ════════════════════════════════════════════════════════════════

# عنوان الـ REST API للـ backend (Laravel) — مستضاف خارج Vercel.
# يجب أن ينتهي بـ /api ، مثال:
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api
